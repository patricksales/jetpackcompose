# === Build and caches ===
# Gradle / build artifacts
**/build/
.gradle/

# Keep gradle wrapper files tracked (do NOT ignore the wrapper jar/properties)
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# Kotlin / Kotlin/Native / KMP caches
.konan/
.cinterop/
.cocoapods/
.kotlin/
.gradle-kotlin-dsl/
.kotlinc/

# Temporary / output
*.class
*.log
*.tmp
tmp/

# === IDEs ===
# IntelliJ / Android Studio
.idea/
*.iml
*.ipr
*.iws

# VS Code
.vscode/

# === OS ===
.DS_Store
Thumbs.db

# === Android specific ===
local.properties          # contains local SDK paths - should not be committed
*.apk
*.ap_
*.aab
*.keystore

# Android Studio Captures
captures/

# === Kotlin Multiplatform / Native (iOS) ===
# K/N framework outputs and Xcode build products
**/*.framework
**/*.dSYM
**/*.xcframework

# CocoaPods/Swift Package Manager artifacts
Pods/
Podfile.lock
Package.resolved
.build/

# === Xcode / iOS ===
# User-specific and derived data
xcuserdata/
*.xcuserstate
*.xcscmblueprint
DerivedData/
*.playground/
*.xcworkspace/xcuserdata/

# Keep shared workspace/schemes tracked (do not ignore xcshareddata)
# /.xcworkspace/xcshareddata/   <-- DO NOT add this to ignore (shared schemes often needed)

# Xcode build directories
**/Build/
**/build/   # already covered above but harmless to repeat

# === Misc / Security ===
*.env
*.keystore
/secrets.properties
